# env 템플릿 — 이 파일은 GitHub 에 푸시됩니다 (값은 비워둘 것).
# 새 환경에서 `.env.example` 를 `.env` 로 복사한 뒤 실제 값을 채워 넣으세요.
#   cp .env.example .env
#
# 주의: 브라우저(클라이언트)에 노출되는 값은 NEXT_PUBLIC_ 접두사가 필요하지만,
#       비밀 키(API_KEY 등)는 절대 NEXT_PUBLIC_ 을 붙이지 말 것 (노출됨).

# 서버 전용 비밀 키 (클라이언트에 노출 금지)
API_KEY=

# 클라이언트에서 사용해도 되는 공개 값
# NEXT_PUBLIC_API_BASE_URL=
